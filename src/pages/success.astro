---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Message sent — Max Burgess Studio"
  description="Thank you for your enquiry."
>
  <section class="min-h-screen flex items-center justify-center px-6 bg-white">
    <div class="text-center max-w-sm">
      <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 font-light mb-6">
        Thank you
      </p>
      <h1 class="font-display font-light text-3xl md:text-4xl tracking-wide mb-5 text-neutral-900">
        Message received.
      </h1>
      <p class="text-sm font-light leading-relaxed text-neutral-500 mb-10">
        I'll be in touch shortly.
      </p>
      <a
        href="/"
        class="text-xs tracking-[0.35em] uppercase font-light text-neutral-500 border-b border-neutral-300 pb-0.5 hover:text-neutral-900 hover:border-neutral-600 transition-all duration-300"
      >
        Back to studio
      </a>
    </div>
  </section>
</Layout>

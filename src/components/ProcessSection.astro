---
import { t, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;
const i = t(lang).process;
---
<section id="process" class="py-24 px-6 md:px-12 lg:px-20 bg-white">
  <div class="max-w-7xl mx-auto">

    <h2 class="font-display font-light text-3xl md:text-4xl lg:text-5xl tracking-wide mb-16">
      {i.heading}
    </h2>

    <!-- Horizontal on desktop, stacked on mobile -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-8">
      {i.steps.map((step) => (
        <div class="border-t border-neutral-200 pt-6">
          <p class="text-[10px] tracking-[0.4em] uppercase text-neutral-400 mb-4 font-light">
            {step.number}
          </p>
          <h3 class="font-display font-light text-2xl mb-3">
            {step.title}
          </h3>
          <p class="text-sm font-light leading-relaxed text-neutral-600">
            {step.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

---
import works from '../data/works.json';
---
<section id="work" class="py-24 px-6 md:px-12 lg:px-20 bg-white">
  <div class="max-w-7xl mx-auto">

    <!-- Masonry-style columns grid -->
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-5">
      {works.map((work) => (
        <div class="break-inside-avoid mb-5 group relative overflow-hidden">
          <a
            href={work.image}
            class="glightbox block relative overflow-hidden"
            data-gallery="works"
            data-title={`${work.title}, ${work.year}`}
            data-description={`${work.edition} · ${work.sizes.join(' / ')}`}
          >
            <!-- Placeholder image div — replace with <img> when images are ready -->
            <div
              class={`bg-[#2a2a2a] w-full ${work.orientation === 'landscape' ? 'aspect-[4/3]' : 'aspect-[3/4]'}`}
            ></div>

            <!-- Hover overlay -->
            <div
              class="absolute inset-0 bg-black/55 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex flex-col justify-end p-5 text-white"
            >
              <p class="font-display font-light text-xl leading-snug mb-1.5">
                {work.title}
              </p>
              <p class="text-[10px] tracking-[0.3em] uppercase text-white/55 mb-1">
                {work.edition}
              </p>
              <p class="text-[10px] tracking-[0.15em] text-white/45">
                {work.sizes.join(' / ')}
              </p>
            </div>
          </a>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import GLightbox from 'glightbox';
  GLightbox({ selector: '.glightbox' });
</script>

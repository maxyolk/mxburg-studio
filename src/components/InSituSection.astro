---
// In-situ / installation shots — replace placeholder divs with <img> tags
const shots = [
  { id: 1, alt: 'Print installed in a hotel lobby, warm evening light' },
  { id: 2, alt: 'Diptych above a credenza in a private residence' },
  { id: 3, alt: 'Large format print in a boardroom setting' },
  { id: 4, alt: 'Gallery wall arrangement in an open-plan office' },
  { id: 5, alt: 'Single oversized print in a minimal corridor' },
  { id: 6, alt: 'Framed series in a boutique hotel bedroom' },
];
---
<section id="in-situ" class="py-24 px-6 md:px-12 lg:px-20 bg-[#f7f6f4]">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-14">
      <h2 class="font-display font-light text-3xl md:text-4xl lg:text-5xl tracking-wide mb-5">
        The work, in place.
      </h2>
      <p class="text-sm font-light leading-relaxed text-neutral-600 max-w-xl">
        Each piece is considered for the space it will inhabit.
        We offer curation consultations before any commitment.
      </p>
    </div>

    <!-- Mobile: horizontal scroll — Desktop: 3-column grid -->
    <div
      class="
        flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4
        md:grid md:grid-cols-3 md:overflow-visible md:gap-5 md:pb-0
        scrollbar-none
      "
    >
      {shots.map((shot) => (
        <!-- Each card: landscape 16:9 -->
        <div
          class="
            flex-none w-[80vw] snap-start
            md:w-auto md:flex-auto
          "
        >
          <!-- Placeholder: replace with <img src={shot.src} alt={shot.alt} class="w-full aspect-video object-cover" /> -->
          <div class="w-full aspect-video bg-[#2a2a2a]"></div>
        </div>
      ))}
    </div>

  </div>
</section>

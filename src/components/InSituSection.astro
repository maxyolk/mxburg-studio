---
import { t, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;
const i = t(lang).inSitu;
// In-situ / installation shots — replace placeholder divs with <img> tags
const shots = [
  { src: '/images/insitu/001.jpg', alt: 'Cyclist beneath a misty iron bridge' },
  { src: '/images/insitu/002.jpg', alt: 'Woman passing a lit café window, Kraków old town' },
  { src: '/images/insitu/003.jpg', alt: 'Figure walking in snowfall against a stone wall' },
  { src: '/images/insitu/004.jpg', alt: 'Man walking through a Gothic arch, Wawel courtyard' },
  { src: '/images/insitu/005.jpg', alt: 'Footprints seen through a glass floor panel' },
  { src: '/images/insitu/006.jpg', alt: 'Pigeons lifting from a foggy Kraków square' },
];
---
<section id="in-situ" class="py-24 px-6 md:px-12 lg:px-20 bg-[#f7f6f4]">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-14">
      <h2 class="font-display font-light text-3xl md:text-4xl lg:text-5xl tracking-wide mb-5">
        {i.heading}
      </h2>
      <p class="text-sm font-light leading-relaxed text-neutral-600 max-w-xl">
        {i.subtext}
      </p>
    </div>

    <!-- Mobile: horizontal scroll — Desktop: 3-column grid -->
    <div
      class="
        flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4
        md:grid md:grid-cols-3 md:overflow-visible md:gap-5 md:pb-0
        scrollbar-none
      "
    >
      {shots.map((shot) => (
        <!-- Each card: landscape 16:9 -->
        <div
          class="
            flex-none w-[80vw] snap-start
            md:w-auto md:flex-auto
          "
        >
          <img
            src={shot.src}
            alt={shot.alt}
            class="w-full aspect-[3/4] object-cover"
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>

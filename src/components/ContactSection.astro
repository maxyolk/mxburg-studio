---
import { t, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;
const i = t(lang).contact;
---
<section id="contact" class="py-24 px-6 md:px-12 lg:px-20 bg-[#1a1a1a] text-white">
  <div class="max-w-2xl mx-auto">

    <h2 class="font-display font-light text-3xl md:text-4xl lg:text-5xl tracking-wide mb-4">
      {i.heading}
    </h2>
    <p class="text-sm font-light text-white/55 tracking-wide mb-12">
      {i.subtext}
    </p>

    <form
      name="project-enquiry"
      method="POST"
      action={lang === 'pl' ? '/pl/success' : '/success'}
      data-netlify="true"
      class="space-y-6"
    >
      <!-- Required hidden field for Netlify Forms -->
      <input type="hidden" name="form-name" value="project-enquiry" />

      <div>
        <label for="name" class="block text-[10px] tracking-[0.35em] uppercase text-white/40 mb-2 font-light">
          {i.fields.name.label}
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full bg-transparent border-b border-white/20 pb-2 text-sm font-light text-white placeholder:text-white/25 focus:outline-none focus:border-white/50 transition-colors duration-200"
          placeholder={i.fields.name.placeholder}
        />
      </div>

      <div>
        <label for="email" class="block text-[10px] tracking-[0.35em] uppercase text-white/40 mb-2 font-light">
          {i.fields.email.label}
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full bg-transparent border-b border-white/20 pb-2 text-sm font-light text-white placeholder:text-white/25 focus:outline-none focus:border-white/50 transition-colors duration-200"
          placeholder={i.fields.email.placeholder}
        />
      </div>

      <div>
        <label for="project-type" class="block text-[10px] tracking-[0.35em] uppercase text-white/40 mb-2 font-light">
          {i.fields.projectType.label}
        </label>
        <select
          id="project-type"
          name="project-type"
          required
          class="w-full bg-[#1a1a1a] border-b border-white/20 pb-2 text-sm font-light text-white/80 focus:outline-none focus:border-white/50 transition-colors duration-200 appearance-none cursor-pointer"
        >
          <option value="" disabled selected class="text-white/30">{i.fields.projectType.placeholder}</option>
          {i.projectTypes.map((type) => (
            <option value={type} class="bg-[#1a1a1a]">{type}</option>
          ))}
        </select>
      </div>

      <div>
        <label for="message" class="block text-[10px] tracking-[0.35em] uppercase text-white/40 mb-2 font-light">
          {i.fields.message.label}
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full bg-transparent border-b border-white/20 pb-2 text-sm font-light text-white placeholder:text-white/25 focus:outline-none focus:border-white/50 transition-colors duration-200 resize-none"
          placeholder={i.fields.message.placeholder}
        ></textarea>
      </div>

      <div class="pt-4">
        <button
          type="submit"
          class="text-xs tracking-[0.35em] uppercase font-light text-white/80 border-b border-white/30 pb-0.5 hover:text-white hover:border-white/70 transition-all duration-300 cursor-pointer"
        >
          {i.submit}
        </button>
      </div>
    </form>

  </div>
</section>
